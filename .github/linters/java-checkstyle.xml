<?xml version="1.0"?>
<!DOCTYPE module PUBLIC "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN" "https://checkstyle.org">
<module name="Checker">

    <!-- Förbjuder Tab-tecken (använd mellanslag istället) -->
    <module name="FileTabCharacter"/>

    <module name="TreeWalker">
        <!-- INDRAG OCH MELLANSLAG -->
        <module name="Indentation">
            <property name="basicOffset" value="4"/>      <!-- Standard 4 mellanslag -->
            <property name="braceAdjustment" value="0"/>
            <property name="caseIndent" value="4"/>
        </module>

        <module name="WhitespaceAround">
            <!-- Kollar mellanslag runt tecken som =, +, {, } etc. -->
            <property name="allowEmptyConstructors" value="true"/>
            <property name="allowEmptyMethods" value="true"/>
        </module>

        <module name="NoWhitespaceBefore"/>    <!-- Inga mellanslag före semikolon ; -->
        <module name="NoWhitespaceAfter"/>     <!-- Inga mellanslag efter t.ex. dot . -->

        <!-- ORDNING OCH REDA -->
        <module name="AvoidStarImport"/>  <!-- Inga .* imports -->
        <module name="UnusedImports"/>    <!-- Hittar imports som inte används -->
        <module name="RedundantImport"/>  <!-- Inga dubbel-imports -->
        <module name="NeedBraces"/>       <!-- Tvingar fram { } även för korta if-satser -->
        <module name="LeftCurly"/>        <!-- Måsvinge { ska sitta på samma rad -->
        <module name="RightCurly"/>       <!-- Måsvinge } på egen rad -->
    </module>
</module>

